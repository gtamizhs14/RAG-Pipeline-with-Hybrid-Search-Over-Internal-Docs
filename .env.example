# ============================================================
# RAG Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored so API keys never get committed.
# ============================================================

# ── LLM Provider (Groq) ──────────────────────────────────────
# Free API key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model used for Q&A generation and citation verification
# Available Groq models: llama3-70b-8192, llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama3-70b-8192

# Model used as LLM-as-judge during evaluation (can be same model or stronger)
GROQ_JUDGE_MODEL=llama3-70b-8192

# ── Embeddings (runs locally — no API key needed) ────────────
# SentenceTransformers model name from HuggingFace Hub.
# Swap this to any model by editing one line here.
#   all-MiniLM-L6-v2  → 384-dim,  fast,    great quality (~90% of OpenAI)
#   all-mpnet-base-v2 → 768-dim,  slower,  higher quality
#   multi-qa-mpnet-base-dot-v1 → 768-dim, tuned for Q&A retrieval
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Must match the chosen model's output dimension exactly.
#   all-MiniLM-L6-v2       → 384
#   all-mpnet-base-v2       → 768
#   multi-qa-mpnet-...      → 768
EMBEDDING_DIMENSION=384

# ── ChromaDB (local file-based vector store) ─────────────────
# Where ChromaDB persists its index on disk
CHROMA_DB_PATH=data/chroma_db

# Name of the ChromaDB collection (logical namespace for your documents)
CHROMA_COLLECTION_NAME=documents

# ── BM25 Sparse Index ────────────────────────────────────────
# Pickled BM25 index stored alongside ChromaDB
BM25_INDEX_PATH=data/bm25_index.pkl

# ── Chunking Configuration ───────────────────────────────────
# Characters per chunk for fixed-size and recursive-header strategies
CHUNK_SIZE=512

# Characters of overlap between consecutive chunks.
# Preserves context for sentences that span chunk boundaries.
CHUNK_OVERLAP=64

# For semantic chunking: cosine similarity below this value triggers a topic boundary.
# Lower = more chunks (fine-grained), Higher = fewer chunks (coarse-grained).
SEMANTIC_SIMILARITY_THRESHOLD=0.5

# ── Deduplication ─────────────────────────────────────────────
# Chunks whose cosine similarity to an existing chunk exceeds this are skipped.
DEDUP_SIMILARITY_THRESHOLD=0.95

# ── Retrieval ─────────────────────────────────────────────────
# Candidates fetched from each retriever (dense + sparse) before fusion
RETRIEVAL_TOP_K=20

# Final chunks kept after reranking — these go to the LLM as context
RERANK_TOP_N=5

# RRF constant — dampens the impact of very high rankings.
# 60 is the standard value from the original RRF paper.
RRF_K=60

# Weighted fallback weights (not used by RRF, reserved for future use)
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# Cross-encoder reranker model (from HuggingFace, runs locally)
# ms-marco-MiniLM-L-6-v2 is fast and strong for passage reranking
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Set to False to skip reranking (faster but less accurate)
USE_RERANKER=True

# ── Paths ─────────────────────────────────────────────────────
# Drop your documents here before running ingest.py
RAW_DOCS_PATH=data/raw
